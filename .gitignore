# Replace .gitignore with the comprehensive version
@"
# Next.js
.next/
out/
build/
dist/

# Dependencies
node_modules/
.npm/

# Environment
.env
.env.local
.env*.local

# Python API
api/venv/
api/env/
api/__pycache__/
api/*.pyc
api/*.pyo
api/*.pyd
api/trustlayer.db
api/*.sqlite3
api/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn

# Vercel
.vercel

# Temporary files
*.tmp
*.temp
*.cache

# Large files
*.sst
*.sst.*
*.tar
*.gz
*.zip
"@ | Out-File -FilePath .gitignore -Encoding UTF8